# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=travelpilot

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Groq API key for the AI chatbot — PRIMARY provider (server-side proxy for
# logged-in users). Groq's free tier (~1,000 requests/day, no credit card)
# is far more workable for testing than Gemini's free tier.
# Get a free key at https://console.groq.com -> API Keys -> Create API Key
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key — SECONDARY fallback, only used if Groq isn't configured
# or a Groq call fails. Get a free key at https://aistudio.google.com/app/apikey
# Optional: if BOTH are left unset, the backend falls back to a built-in
# rule-based assistant so /api/chat/message keeps working regardless.
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio — powers real SOS + group-invite SMS/WhatsApp messages.
# Sign up free at https://www.twilio.com/try-twilio, then:
#  - TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN: Console dashboard homepage.
#  - TWILIO_SMS_FROM: a Twilio phone number (Phone Numbers > Buy a number;
#    trial accounts get one free number, e.g. +1415XXXXXXX).
#  - TWILIO_WHATSAPP_FROM: the Twilio Sandbox for WhatsApp number, formatted
#    as "whatsapp:+14155238886" (Messaging > Try it out > Send a WhatsApp
#    message). Each recipient must first send the sandbox's join code from
#    their own WhatsApp once — that's a Twilio sandbox requirement, not a
#    TravelPilot one, and goes away once you apply for a production sender.
# Optional: if left unset, SOS/invites still work end-to-end (alerts and
# invite records are still created) but messages are only logged to the
# server console instead of actually being sent.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMTP — powers real "Forgot password" emails.
# Easiest free option: a Gmail account with an App Password (Google
# Account -> Security -> 2-Step Verification -> App passwords). Regular
# Gmail passwords won't work here, it must be an App Password.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=the 16-character app password (no spaces)
#   SMTP_FROM=youraddress@gmail.com
# Optional: if left unset, reset links are just logged to the server
# console (and returned in the API response outside production) instead
# of emailed, so this stays testable without a mail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_email@gmail.com

# Google Sign-In — lets users log in with their Google account.
# Free setup at https://console.cloud.google.com/apis/credentials:
#   1. Create a project (or use an existing one).
#   2. Configure the OAuth consent screen (External, add your email as a
#      test user while in testing mode).
#   3. Create Credentials -> OAuth client ID -> Application type: Web
#      application.
#   4. Add http://localhost:5173 under "Authorized JavaScript origins".
#   5. Copy the Client ID — set it here AND as VITE_GOOGLE_CLIENT_ID in
#      frontend/.env (same value in both places).
# Optional: if left unset, the "Sign in with Google" button is hidden.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
