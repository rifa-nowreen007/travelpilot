VITE_API_URL=http://localhost:5000/api

# Gemini API key for the client-side demo AI chat (guest/demo sessions only).
# Logged-in users are routed through the backend's Gemini proxy instead, so
# their traffic never needs this key in the browser.
# Get a free key at https://aistudio.google.com/app/apikey
# NEVER commit your real key — this file is just a template.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary — free photo storage (25GB) for receipt photos and trip diary
# photos. Sign up free at https://cloudinary.com, no card required.
#   VITE_CLOUDINARY_CLOUD_NAME: shown on your Cloudinary dashboard homepage.
#   VITE_CLOUDINARY_UPLOAD_PRESET: Settings -> Upload -> Upload presets ->
#     Add upload preset -> set "Signing Mode" to "Unsigned" -> Save, then
#     copy the preset name here. Unsigned presets are safe to use directly
#     from the browser (no secret key involved) and are the standard way
#     to do client-side uploads with Cloudinary's free tier.
# Optional: if left unset, photo upload buttons are hidden and receipt
# scanning still works from a locally-picked file (just isn't saved).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Google Sign-In client ID — must match backend/.env's GOOGLE_CLIENT_ID
# exactly. See backend/.env.example for free setup steps.
# Optional: if left unset, the "Sign in with Google" button is hidden.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
